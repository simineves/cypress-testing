  "description": "MLS WebApp E2E Automation Test using Cypress",
  "main": "index.js",
  "scripts": {
    "test:prod-report": "npx cypress run  --headed --browser chrome --config-file ./cypress.mls.config.js",
    "test:prod-report-headless": "npx cypress run --config-file ./cypress.mls.config.js",
    "test:prod": "npx cypress open --config-file ./cypress.mls.config.js",
    "test:cli-prod": "npx cypress open --record --key 7e187f6c-0256-415b-bcc1-dcae95d9b00a --browser chrome --spec 'cypress/E2E' --config-file ./cypress.mls.config.js",
    "livetest": "node scripts/livetest.js"
  },
