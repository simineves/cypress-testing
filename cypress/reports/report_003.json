              "context": null,
              "code": "const todayString = getTodayString(); // Get today's date\ncy.visit(`${webAppBaseURL}/schedule/scores`);\ncy.wait(5000);\ncy.get(\".mls-c-schedule__matches\").then(schedule => {\n  if (schedule.find('div[class*=\"mls-c-match-tile --live\"]').length > 0) {\n    cy.get('div[class*=\"mls-c-match-tile --live\"]').each($div => {\n      const liveMatchLink = $div.parent(\"a\").prop(\"href\");\n      if (liveMatchLink) {\n        const matchInfo = getTeamsAndDateFromURL(liveMatchLink);\n        if (matchInfo && matchInfo.MatchDate === todayString) {\n          liveMatchURLs.push(liveMatchLink);\n        }\n      }\n    });\n  } else {\n    cy.log(\"No live matches found.\");\n  }\n  const liveMatchObj = {\n    liveMatchURLs\n  };\n  cy.writeFile(\"MLS_LIVE_SMOKE_TEST_URLS.json\", liveMatchObj);\n  cy.log(`liveMatchURLs array written to: MLS_LIVE_SMOKE_TEST_URLS.json`);\n});",
